# Neon Postgres connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret used to sign session cookies (generate with: openssl rand -base64 32)
SESSION_SECRET=""

# bcrypt hash of the single admin password (generate with the scripts/hash-password.ts helper)
ADMIN_PASSWORD_HASH=""

# Only needed to run scripts/migrate-data.ts once against the original Supabase project (read-only export).
# The anon/publishable key is enough since the source table's RLS policies already allow public reads.
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
